#!/bin/bash
# Copyright (C) 2000 ZeroDream

# --------------------------------------------------

cd "$WRT_MainPath/"

# --------------------------------------------------

# ! 由 ZeroDream 私有

[[ -z "$ZeroDream_Secret" ]] && exit 2

# ParseZeroWrtPackage
outputPath="$ZD_TempPath/ParseZeroWrtPackage" && mkdir -p "$outputPath"
"$ZD_AppPath/ParseZeroWrtPackage-linux-amd64" \
  --dataPath "$WRT_MainPath/bin" \
  --configPath "$GITHUB_WORKSPACE/config/PackageConfig" \
  --outputPath "$outputPath"
(($? != 0)) && exit 2

# --------------------------------------------------

exit 0
