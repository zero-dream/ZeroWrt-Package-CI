#!/bin/bash
# Copyright (C) 2000 ZeroDream

# --------------------------------------------------

cd "$GITHUB_WORKSPACE/$WRT_DIR/"

# ParseZeroWrtPackageApp
ParseZeroWrtPackageApp="$GITHUB_WORKSPACE/Application/ParseZeroWrtPackage-linux-amd64"
chmod +x "$ParseZeroWrtPackageApp"

# ParseZeroWrtPackage
outputPath="$ZD_TempPath/ParseZeroWrtPackage"
mkdir -p "$outputPath"
"$ParseZeroWrtPackageApp" \
  --dataPath "$GITHUB_WORKSPACE/$WRT_DIR/bin" \
  --configPath "$GITHUB_WORKSPACE/Config/CompilePackage" \
  --outputPath "$outputPath"

# --------------------------------------------------

exit 0
